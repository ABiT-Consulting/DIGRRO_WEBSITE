VITE_DEV_PORT=5174
FRONTEND_URL=http://127.0.0.1:5174
ACADEMY_ENV=development
# Compatibility alias for older academy scripts:
# ACADEMY_BASE_URL=

# Google Analytics 4 measurement ID for the public academy page
VITE_GOOGLE_ANALYTICS_ID=G-RH6L7EDCHK
# Runtime alias accepted by academy/api/public-config.php
GOOGLE_ANALYTICS_ID=G-RH6L7EDCHK

# Stripe credentials
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY_TEST=
STRIPE_SECRET_KEY_LIVE=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_WEBHOOK_SECRET_LIVE=
# Compatibility alias also accepted by the build script:
# STRIPE_SECRET=

# Legacy aliases still supported
Publishable key=
publishable_key=
# Keep these blank for local development unless they contain a test-mode key.
STRIPE_SECRET_KEY=
Secret key=
secret_key=

# Optional: existing Stripe test Payment Link URLs for local development.
# Prefer STRIPE_SECRET_KEY_TEST so local registration creates Checkout Sessions.
STRIPE_TEST_PAYMENT_LINK_TEST=
STRIPE_TEST_PAYMENT_LINK_SPRINT=
STRIPE_TEST_PAYMENT_LINK_BOOTCAMP=
STRIPE_TEST_PAYMENT_LINK_CORPORATE=

# Optional: existing Stripe live Payment Link URLs for production fallback only.
STRIPE_LIVE_PAYMENT_LINK_TEST=
STRIPE_LIVE_PAYMENT_LINK_SPRINT=
STRIPE_LIVE_PAYMENT_LINK_BOOTCAMP=
STRIPE_LIVE_PAYMENT_LINK_CORPORATE=

# SMTP credentials for academy/api/*.php
emailaddress=system@digrro.com
password=
Incoming Server=mail.abitcons.com
IMAP Port=993
IMAP Encryption=SSL/TLS
Outgoing Server=mail.abitcons.com
SMTP Port=465
SMTP Encryption=SSL/TLS
Alternate SMTP Port=587

# Compatibility aliases also accepted by the PHP backend and server.cjs
EMAIL_USER=system@digrro.com
EMAIL_PASS=

# Optional standard aliases supported by the PHP backend
SMTP_USERNAME=system@digrro.com
SMTP_PASSWORD=
SMTP_HOST=mail.abitcons.com
SMTP_PORT=465
SMTP_FROM_EMAIL=system@digrro.com
SMTP_FROM_NAME=Digrro Academy

# Academy teacher portal (course manager) - required to enable /academy/admin.html
# Generate hash:    npm run academy:hash YOUR_PASSWORD
# Generate secret:  npm run academy:secret
# Hash format expected: scrypt:<salt-hex>:<derived-hex>
ACADEMY_ADMIN_EMAIL=
ACADEMY_ADMIN_PASSWORD_HASH=
ACADEMY_ADMIN_TOKEN_SECRET=
ACADEMY_ADMIN_TOKEN_TTL=28800

# Optional student portal token settings. If omitted, ACADEMY_ADMIN_TOKEN_SECRET is reused.
ACADEMY_STUDENT_TOKEN_SECRET=
ACADEMY_STUDENT_TOKEN_TTL=2592000
ACADEMY_PASSWORD_RESET_TTL=3600

# Optional app-managed one-time promo codes.
# Each code can be assigned to one email and applies the percentage before Stripe Checkout.
# Example:
# ACADEMY_PROMO_CODES=[{"code":"VIP50","email":"student@example.com","discountPercent":50,"description":"Private invite"}]
ACADEMY_PROMO_CODES=
