VITE_DEV_PORT=5174
FRONTEND_URL=http://127.0.0.1:5174
# Compatibility alias for older academy scripts:
# ACADEMY_BASE_URL=

# Stripe credentials
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Compatibility alias also accepted by the build script:
# STRIPE_SECRET=

# Legacy aliases still supported
Publishable key=
Secret key=
publishable_key=
secret_key=

# Optional: use existing Stripe Payment Link URLs instead of a secret key locally
STRIPE_PAYMENT_LINK_TEST=https://buy.stripe.com/7sY28s2pzaY25a33OsbQY05
STRIPE_PAYMENT_LINK_SPRINT=https://buy.stripe.com/7sY28s2pzaY25a33OsbQY05
STRIPE_PAYMENT_LINK_BOOTCAMP=https://buy.stripe.com/aFa00ke8h1nscCvfxabQY03
STRIPE_PAYMENT_LINK_CORPORATE=https://buy.stripe.com/28E6oI4xH4zE6e73OsbQY04

# SMTP credentials for academy/api/*.php
emailaddress=system@digrro.com
password=
Incoming Server=mail.abitcons.com
IMAP Port=993
IMAP Encryption=SSL/TLS
Outgoing Server=mail.abitcons.com
SMTP Port=465
SMTP Encryption=SSL/TLS
Alternate SMTP Port=587

# Compatibility aliases also accepted by the PHP backend and server.cjs
EMAIL_USER=system@digrro.com
EMAIL_PASS=

# Optional standard aliases supported by the PHP backend
SMTP_USERNAME=system@digrro.com
SMTP_PASSWORD=
SMTP_HOST=mail.abitcons.com
SMTP_PORT=465
SMTP_FROM_EMAIL=system@digrro.com
SMTP_FROM_NAME=Digrro Academy

# Academy teacher portal (course manager) - required to enable /academy/admin.html
# Generate hash:    npm run academy:hash YOUR_PASSWORD
# Generate secret:  npm run academy:secret
# Hash format expected: scrypt:<salt-hex>:<derived-hex>
ACADEMY_ADMIN_EMAIL=
ACADEMY_ADMIN_PASSWORD_HASH=
ACADEMY_ADMIN_TOKEN_SECRET=
ACADEMY_ADMIN_TOKEN_TTL=28800

# Optional student portal token settings. If omitted, ACADEMY_ADMIN_TOKEN_SECRET is reused.
ACADEMY_STUDENT_TOKEN_SECRET=
ACADEMY_STUDENT_TOKEN_TTL=2592000
ACADEMY_PASSWORD_RESET_TTL=3600
